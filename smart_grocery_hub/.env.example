# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to version control.

# --- Django core ---
SECRET_KEY=django-insecure-change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --- Database (MySQL) ---
# If you don't have MySQL set up yet, leave DB_ENGINE as sqlite to get
# started immediately, then switch to mysql once your DB is ready.
DB_ENGINE=sqlite
# DB_ENGINE=mysql
DB_NAME=smart_grocery_hub
DB_USER=root
DB_PASSWORD=change_me
DB_HOST=127.0.0.1
DB_PORT=3306

# --- Email (for verification / password reset) ---
# Leave as console backend during development: emails print to the terminal.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
